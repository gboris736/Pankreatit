<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pancreatitis.ui.QuestionListTableViewTrainSetController">
    <padding>
        <Insets bottom="15" left="20" right="20" top="15" />
    </padding>

    <Label text="Обучающая выборка" textAlignment="CENTER">
        <font>
            <Font name="System Bold" size="20" />
        </font>
    </Label>

    <Separator />

    <!-- Ряд с выбором файла, статусом и кнопками – растягивается на всю ширину -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <!-- Левая часть: выбор файла -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Файл алгоритма:" />
            <ComboBox fx:id="cmbAlgorithmFile" prefWidth="280.0" promptText="Выберите версию" />
        </HBox>

        <!-- Распорка – занимает всё доступное пространство между левым и правым блоком -->
        <Region HBox.hgrow="ALWAYS" />

        <!-- Правая часть: статус и кнопки -->
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label fx:id="lblStatus" text="" style="-fx-text-fill: #6c757d;"/>
            <Button fx:id="btnSave" text="💾 Сохранить изменения"
                    styleClass="btn-save" onAction="#saveChangesAsync"/>
            <Button fx:id="btnSubmit" text="💾 Отправить изменения"
                    styleClass="btn-save" onAction="#submitChangesAsync"/>
        </HBox>
    </HBox>

    <!-- Поле поиска и счётчик – растягивается на всю ширину -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <padding>
            <Insets top="0" right="10" bottom="10" left="10"/>
        </padding>
        <TextField fx:id="searchField" promptText="Поиск..." HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel" text="Найдено: 0"/>
    </HBox>

    <!-- Главная область: две таблицы с кнопками перемещения – занимает всё оставшееся место -->
    <HBox alignment="TOP_CENTER" spacing="10" VBox.vgrow="ALWAYS">
        <!-- Таблица анкет не в выборке -->
        <TableView fx:id="tableViewUsualQuestion" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colSelectUQ" minWidth="25" prefWidth="30.0" text="Действие" />
                <TableColumn fx:id="colNamePersonUQ" prefWidth="180.0" text="ФИО пациента" />
                <TableColumn fx:id="colDateUQ" prefWidth="200.0" text="Дата создания анкеты" />
                <TableColumn fx:id="colDiagnosisUQ" prefWidth="273.0" text="Поставленный диагноз" />
                <TableColumn fx:id="colDoctorUQ" prefWidth="273.0" text="Ответственный врач" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <placeholder>
                <Label text="Нет анкет не в обучающей выборке" textAlignment="CENTER" />
            </placeholder>
        </TableView>

        <!-- Кнопки перемещения -->
        <VBox alignment="CENTER" spacing="15" minWidth="40">
            <Button fx:id="btnAddToTrain" text="➡️"
                    onAction="#handleMoveToTrain"
                    style="-fx-base: #28a745; -fx-text-fill: white;"/>
            <Button fx:id="btnRemoveFromTrain" text="⬅️"
                    onAction="#handleMoveToUsual"
                    style="-fx-base: #dc3545; -fx-text-fill: white;"/>
        </VBox>

        <!-- Таблица анкет в обучающей выборке -->
        <TableView fx:id="tableViewTrainQuestion" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colSelectTQ" minWidth="25" prefWidth="20.0" text="Действие" />
                <TableColumn fx:id="colNamePersonTQ" prefWidth="180.0" text="ФИО пациента" />
                <TableColumn fx:id="colDateTQ" prefWidth="100.0" text="Дата создания анкеты" />
                <TableColumn fx:id="colDiagnosisTQ" prefWidth="273.0" text="Поставленный диагноз" />
                <TableColumn fx:id="colDoctorTQ" prefWidth="273.0" text="Ответственный врач" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <placeholder>
                <Label text="Нет анкет в обучающей выборке" textAlignment="CENTER" />
            </placeholder>
        </TableView>
    </HBox>

    <!-- Легенда цветов -->
    <HBox fx:id="legendBox" spacing="8" />

</VBox>